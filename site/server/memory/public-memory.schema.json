{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GuidePublicMemory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "updated_at",
    "window_days",
    "scene_hint_profiles",
    "hot_questions_by_spot",
    "common_confusions",
    "route_acceptance_patterns",
    "blind_spots"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "window_days": {
      "type": "integer",
      "minimum": 1
    },
    "scene_hint_profiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sceneHintProfile"
      }
    },
    "hot_questions_by_spot": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hotQuestionBySpot"
      }
    },
    "common_confusions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/commonConfusion"
      }
    },
    "route_acceptance_patterns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/routeAcceptancePattern"
      }
    },
    "blind_spots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blindSpot"
      }
    }
  },
  "$defs": {
    "baseStats": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence",
        "evidence_count",
        "last_seen_at"
      ],
      "properties": {
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_seen_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "sceneHintProfile": {
      "allOf": [
        {
          "$ref": "#/$defs/baseStats"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scene_id",
            "trigger",
            "hint_text",
            "cooldown_minutes"
          ],
          "properties": {
            "scene_id": {
              "type": "string"
            },
            "trigger": {
              "type": "string"
            },
            "hint_text": {
              "type": "string"
            },
            "cooldown_minutes": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "hotQuestionBySpot": {
      "allOf": [
        {
          "$ref": "#/$defs/baseStats"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "spot_id",
            "question_cluster",
            "answer_strategy",
            "frequency_30d"
          ],
          "properties": {
            "spot_id": {
              "type": "string"
            },
            "question_cluster": {
              "type": "string"
            },
            "answer_strategy": {
              "type": "string"
            },
            "frequency_30d": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "commonConfusion": {
      "allOf": [
        {
          "$ref": "#/$defs/baseStats"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scene_id",
            "confusion_type",
            "symptom",
            "recommended_hint",
            "frequency_30d"
          ],
          "properties": {
            "scene_id": {
              "type": "string"
            },
            "confusion_type": {
              "type": "string"
            },
            "symptom": {
              "type": "string"
            },
            "recommended_hint": {
              "type": "string"
            },
            "frequency_30d": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "routeAcceptancePattern": {
      "allOf": [
        {
          "$ref": "#/$defs/baseStats"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "route_id",
            "entry_scene",
            "best_intro_style",
            "acceptance_rate"
          ],
          "properties": {
            "route_id": {
              "type": "string"
            },
            "entry_scene": {
              "type": "string"
            },
            "best_intro_style": {
              "type": "string"
            },
            "acceptance_rate": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "best_next_stop": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      ]
    },
    "blindSpot": {
      "allOf": [
        {
          "$ref": "#/$defs/baseStats"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "scene_id",
            "overlooked_target",
            "best_recovery_hint"
          ],
          "properties": {
            "scene_id": {
              "type": "string"
            },
            "overlooked_target": {
              "type": "string"
            },
            "best_recovery_hint": {
              "type": "string"
            }
          }
        }
      ]
    }
  }
}
